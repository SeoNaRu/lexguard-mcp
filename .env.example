# 국가법령정보센터 Open API (둘 중 하나만 있어도 됨)
LAW_API_KEY=
# LAWGOKR_OC=

PORT=9099
LOG_LEVEL=INFO

# MCP POST /mcp 분당 요청 제한 (slowapi). Cursor는 다발 요청 → 기본 600/min
# LEXGUARD_MCP_RATE_LIMIT=600/minute

# eflawjosub JSON 빈 조문 시 선택 폴백 (미설정=끔). html | playwright
# playwright: pip install playwright && playwright install chromium
# LEXGUARD_EFLAWJOSUB_FALLBACK=html

# eflawjosub 실네트워크 통합 테스트( pytest tests/test_eflawjosub_integration.py ) — CI 기본 스킵, 로컬에서만 1
# LEXGUARD_RUN_EFLAW_E2E=1
